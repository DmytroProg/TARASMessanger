@using TarasMessenger.Core.Models.Messages

<div class="message @(IsMyMessage ? "my-message" : "other-message")">
    <div class="message-text">@Message.Text</div>
    <div class="d-flex justify-content-between w-100">
        <div class="sender">@(Message.User?.Email ?? "test")</div>
        <div class="date">@Message.SendAt.ToShortTimeString()</div>
    </div>
</div>

@code {
    [Parameter] public TextMessage Message { get; set; }
    [Parameter] public bool IsMyMessage { get; set; }
}